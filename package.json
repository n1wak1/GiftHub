{
  "name": "teleg-escrow",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:backend": "tsx watch src/index.ts",
    "dev:frontend": "npm --prefix miniapp run dev -- --host 127.0.0.1 --port 5173 --strictPort",
    "dev:all": "concurrently -n backend,frontend -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@upstash/redis": "^1.35.0",
    "@fastify/cors": "^11.2.0",
    "@ton/core": "^0.61.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.3.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
