TON_NETWORK=testnet
ESCROW_ADDRESS=UQB32u8KyV9ddFO0Mi34DMCSGiupNot2yfM4Nu8YIVERfrY9
# Same bot as the Mini App — for avatars (GET /profiles/:tgId/avatar) and names of counterparties (GET /profiles/:tgId/telegram).
# TELEGRAM_BOT_TOKEN=123456:ABC...
# Where to save deals-store.json (default: ./data/deals-store.json). On Render with a persistent disk, set mount path here.
# DATA_DIR=/var/data
# Use a single Render instance OR Redis — otherwise seller and buyer may hit different servers and see different deals.
# Free tier: https://upstash.com — create Redis, paste REST URL + token:
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXxx...
# Comma-separated allowed origins for Mini App (Vercel). If unset, all origins are allowed.
# CORS_ORIGIN=https://your-app.vercel.app
# Optional:
# USDT_JETTON_MASTER=
# TONAPI_KEY=
# MIN_FEE_USDT=0.2
# FEE_THRESHOLD_USDT=15
# FEE_BPS_USDT=500
# MIN_FEE_TON=0.02
# FEE_THRESHOLD_TON=15
# FEE_BPS_TON=500

