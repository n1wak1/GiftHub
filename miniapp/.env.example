VITE_API_BASE_URL=http://127.0.0.1:3000
# TON Connect: manifest is always /<origin>/tonconnect-manifest.json (same host as the Mini App).
# Dev (vite): manifest is generated per request — url/iconUrl match current Host (e.g. ngrok).
# Production build: set at build time:
#   VITE_APP_ORIGIN=https://your-domain.com npm run build
# Or replace dist/tonconnect-manifest.json after build.
