# Backend API (Fastify). Из Telegram нужен публичный URL туннеля на порт 3000, не 127.0.0.1.
VITE_API_BASE_URL=http://127.0.0.1:3000

# Манифест TON Connect — только Raw GitHub на JSON (не путать с VITE_API_BASE_URL).
# После push файла miniapp/tonconnect-manifest.json подставь свой commit/branch в путь при необходимости.
VITE_TONCONNECT_MANIFEST_URL=https://raw.githubusercontent.com/n1wak1/GiftHub/main/miniapp/tonconnect-manifest.json
